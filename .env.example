# Copy this file to .env and fill in your credentials
FLASK_SECRET_KEY=change-this-to-something-very-secret

# Planning Center
PCO_PAT=
PCO_APP_ID=

# QuickBooks
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=

# Azure AD (SSO)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_GROUP_ID=
AZURE_REDIRECT_PATH=/callback
AZURE_SCOPE=User.Read GroupMember.Read.All
AZURE_REDIRECT_URI_OVERRIDE=

# Synchronization
SYNC_SCHEDULE=0 0 3 * * 1
DONATION_SYNC_SCHEDULE=0 30 3 * * 1

# Email Notifications
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=
SMTP_PASSWORD=
SMTP_RECIPIENT_EMAIL=
